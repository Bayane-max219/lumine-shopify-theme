<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-logo-text">{{ shop.name }}</span>
      <p class="footer-tagline">{{ section.settings.tagline }}</p>
    </div>

    <div class="footer-nav">
      <h4>Shop</h4>
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    </div>

    <div class="footer-contact">
      <h4>Contact</h4>
      {%- if section.settings.email != blank -%}
        <p><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p>
      {%- endif -%}
      {%- if section.settings.phone != blank -%}
        <p>{{ section.settings.phone }}</p>
      {%- endif -%}
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Timeless style, modern elegance."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number"
    }
  ]
}
{% endschema %}
